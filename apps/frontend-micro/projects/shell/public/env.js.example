// Template cho local dev. Copy file này thành env.js và điền giá trị thực.
// File env.js KHÔNG được commit vào git (đã thêm vào .gitignore)
(function (window) {
  window.__env = window.__env || {};
  window.__env.apiUrl = 'http://localhost:8000';      // URL của iam-service khi dev local
  window.__env.apiPath = '/v1';                       // Direct service dùng /v1; gateway có thể đặt /api/v1
  window.__env.authAuthority = 'https://arda.io.vn';  // OIDC/custom login proxy
  window.__env.authClientId = '370596460112183382';  // Arda SPA client ID trong Zitadel
})(this);
